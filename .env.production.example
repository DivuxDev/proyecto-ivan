# ============================================================
# Variables de entorno para producción (Coolify u otro servidor)
# Configúralas en la UI de Coolify o en un fichero .env
# ============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=tagmap_user
POSTGRES_PASSWORD=CAMBIA_ESTO_PASSWORD_FUERTE
POSTGRES_DB=tagmap_db

# --- JWT (genera uno con: openssl rand -hex 32) ---
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# --- CORS: URL pública del frontend (con https) ---
CORS_ORIGIN=https://TU_DOMINIO.com
