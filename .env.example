# ===========================================
# TagMap - Variables de entorno para Docker Compose
# ===========================================
# Copiar este archivo a .env antes de usar docker compose

# --------------- Base de datos ---------------
POSTGRES_USER=tagmap_user
POSTGRES_PASSWORD=tagmap_secure_password_2024
POSTGRES_DB=tagmap_db

# --------------- Seguridad ---------------
# Cambia este secreto en producción (mínimo 32 caracteres)
JWT_SECRET=change_this_secret_in_production_minimum_32_characters_required

# Duración del token JWT
JWT_EXPIRES_IN=24h

# --------------- Frontend ---------------
# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:3000

# --------------- Almacenamiento ---------------
# Rutas locales para desarrollo (usar named volumes)
UPLOADS_PATH=uploads_data
WATCH_FOLDERS_PATH=watch_folders_data

# Para QNAP NAS (producción), cambia a rutas absolutas:
# UPLOADS_PATH=/share/TagMapUploads
# WATCH_FOLDERS_PATH=/share/TagMapFotos

# --------------- Folder Watcher (Modo NAS) ---------------
# Habilitar importación automática desde carpetas
ENABLE_FOLDER_WATCHER=false

# Directorio donde están las carpetas de equipos
WATCH_FOLDERS_DIR=/share/TagMapFotos

# Intervalo de escaneo en segundos
SCAN_INTERVAL_SECONDS=60
