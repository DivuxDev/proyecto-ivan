# Copia este archivo a .env y rellena los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://lineas_user:lineas_pass@localhost:5432/lineas_db"

# JWT - CAMBIA ESTO POR UN SECRETO ALEATORIO FUERTE (min 32 chars)
JWT_SECRET="cambia_esto_por_un_secreto_muy_fuerte_en_produccion_min32"
JWT_EXPIRES_IN="24h"

# Servidor
PORT=4000
NODE_ENV=development

# CORS - URL del frontend
CORS_ORIGIN="http://localhost:3000"

# Almacenamiento de archivos
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# URL base para generar URLs de imágenes
BASE_URL="http://localhost:4000"
