# Copia este archivo a .env y rellena los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://tagmap_user:tagmap_pass@localhost:5432/tagmap_db"

# JWT - CAMBIA ESTO POR UN SECRETO ALEATORIO FUERTE (min 32 chars)
JWT_SECRET="cambia_esto_por_un_secreto_muy_fuerte_en_produccion_min32"
JWT_EXPIRES_IN="24h"

# Servidor
PORT=4000
NODE_ENV=development

# CORS - URL del frontend
CORS_ORIGIN="http://localhost:3000"

# Almacenamiento de archivos
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# URL base para generar URLs de imágenes
BASE_URL="http://localhost:4000"

# Folder Watcher - Importación automática desde carpetas (modo NAS)
# Habilita el escaneo automático de carpetas organizadas por equipo
ENABLE_FOLDER_WATCHER=false
WATCH_FOLDERS_DIR=/share/TagMapFotos
SCAN_INTERVAL_SECONDS=60
